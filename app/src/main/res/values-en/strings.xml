    <string name="trigger_holdoff_value">Holdoff: %1$s</string>
    <string name="trigger_pre_trigger_ratio_info_title">Pre-trigger ratio</string>
    <string name="trigger_pre_trigger_ratio_info_message">Controls how much margin is kept before the trigger point inside the window. Larger values move the trigger point later and show more leading waveform.</string>
    <string name="trigger_assist_lowpass_info_title">Assist low-pass</string>
    <string name="trigger_assist_lowpass_info_message">A low-pass cutoff used by Trigger to suppress high-frequency switching noise and make the fundamental easier to identify.</string>
    <string name="trigger_autocorr_refresh_info_title">Autocorr. fps</string>
    <string name="trigger_autocorr_refresh_info_message">How often autocorrelation is recomputed. Smaller values are more responsive but use more CPU; larger values save power but respond slower.</string>
    <string name="trigger_autocorr_length_info_title">Autocorr. length</string>
    <string name="trigger_autocorr_length_info_message">How many samples are used for autocorrelation. Longer is steadier but heavier; shorter is faster but can jitter.</string>
    <string name="trigger_hysteresis_info_title">Hysteresis</string>
    <string name="trigger_hysteresis_info_message">Prevents false triggers caused by chatter near threshold. Higher is steadier; lower is more sensitive.</string>
    <string name="trigger_holdoff_info_title">Holdoff</string>
    <string name="trigger_holdoff_info_message">Minimum interval between consecutive triggers to avoid catching multiple edges within one cycle.</string>

