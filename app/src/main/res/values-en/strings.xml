    <string name="trigger_pre_trigger_ratio_value">Pre-trigger ratio: %1$s</string>
    <string name="trigger_assist_lowpass_value">Assist low-pass: %1$sHz</string>
    <string name="trigger_autocorr_refresh_value">Autocorr refresh: %1$d frames</string>
