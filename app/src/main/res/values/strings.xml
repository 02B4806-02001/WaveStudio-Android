    <string name="about_update_v0115_title">0.11.5版本主要更新内容如下：</string>
    <string name="about_update_v0115_item_1">- 均衡器</string>
    <string name="about_update_v0115_item_2">- 修复了监听模式卡顿的问题</string>
    <string name="about_update_v0115_item_3">- 修复了一些其他 bug</string>
    <string name="about_update_v0114_title">0.11.4版本主要更新内容如下：</string>
    <string name="about_update_v0114_item_1">- 滤波器改为默认关闭</string>
    <string name="about_update_v0114_item_2">- 修复了监听模式卡顿的问题</string>
    <string name="about_update_v0114_item_3">- 修复了一些其他 bug</string>
    <string name="about_update_v0113_title">0.11.3版本主要更新内容如下：</string>
    <string name="about_update_v0113_item_1">- 加回“显示/隐藏参考线”按钮</string>
    <string name="about_update_v0113_item_2">- 滤波器与均衡器改为默认开启</string>
    <string name="about_update_v0113_item_3">- 均衡器 Shelf 模式下限制有效Q值</string>
    <string name="about_update_v0113_item_4">- 修复了一些情况下的掉帧问题</string>
    <string name="about_update_v0113_item_5">- 修复了导入音频时监听卡顿的问题</string>
    <string name="about_update_v0113_item_6">- 改动了一些细节</string>
